# Ignore everything by default
*

# Allow the .gitignore itself
!.gitignore

# Allow F1LoginApp and all its contents
!F1LoginApp/
!F1LoginApp/**

# Allow mood-counter and all its contents
!mood-counter/
!mood-counter/**

# Standard node/react-native ignores (sub-folders will have their own or we handle here)
node_modules/
.expo/
dist/
build/
*.log
.DS_Store
